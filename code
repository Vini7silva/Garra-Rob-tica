void processarMovimento() {
  if (!executando) return;
  int* alvos = memorias[sequencia[passoAtual] - 1];
  bool todosNoAlvo = true;

  for (int i = 0; i < 4; i++) {
    int diff = alvos[i] - posAtuais[i];
    if (abs(diff) > 0) {
      todosNoAlvo = false;
      int m = constrain(diff, -passoVelocidade, passoVelocidade);
      posAtuais[i] += m;
      servos[i].write(posAtuais[i]);
    }
  }

  if (todosNoAlvo) {
    static unsigned long pTime = 0;
    if (pTime == 0) pTime = millis();
    if (millis() - pTime > 400) { 
      pTime = 0; passoAtual++;
      if (passoAtual >= tamSeq) {
        if (modoLoop) passoAtual = 0;
        else executando = false;
      }
    }
  }
}

void setup() {
  prefs.begin("garra", false);
  for(int i=0; i<10; i++) {
    for(int j=0; j<4; j++) memorias[i][j] = prefs.getInt(("m"+String(i)+String(j)).c_str(), 90);
  }
  
  WiFi.softAP("GARRA_PRO_FINAL", "12345678");
  
  for(int i=0; i<4; i++) {
    servos[i].setPeriodHertz(50);
    servos[i].attach(pins[i], 500, 2400);
    // Ajuste inicial para o Servo 4 se estiver fora do limite
    if(i==3) posAtuais[i] = constrain(posAtuais[i], 55, 130);
    servos[i].write(posAtuais[i]);
  }

  server.on("/", []() { server.send(200, "text/html", PAGE); });
  
  server.on("/set", []() {
    int i = server.arg("i").toInt(); int v = server.arg("v").toInt();
    if(i==3) v = constrain(v, 55, 130); // ATUALIZADO: Segurança no servidor
    servos[i].write(v); posAtuais[i] = v; server.send(200);
  });

  server.on("/speed", []() { passoVelocidade = server.arg("v").toInt(); server.send(200); });

  server.on("/rec", []() {
    int m = server.arg("m").toInt();
    for(int i=0; i<4; i++) {
      memorias[m][i] = posAtuais[i];
      prefs.putInt(("m"+String(m)+String(i)).c_str(), posAtuais[i]);
    }
    server.send(200);
  });

  server.on("/play", []() {
    int m = server.arg("m").toInt();
    sequencia[0] = m + 1;
    tamSeq = 1; passoAtual = 0; executando = true; modoLoop = false;
    server.send(200);
  });

  server.on("/pSeq", []() {
    String s = server.arg("s"); modoLoop = server.arg("l").toInt();
    tamSeq = 0;
    while(s.length() > 0 && tamSeq < 50) {
      int idx = s.indexOf(',');
      int val = (idx == -1) ? s.toInt() : s.substring(0, idx).toInt();
      if(val >= 1 && val <= 10) sequencia[tamSeq++] = val;
      if(idx == -1) break;
      s = s.substring(idx + 1);
    }
    passoAtual = 0; executando = true; server.send(200);
  });

  server.on("/stop", []() { executando = false; modoLoop = false; server.send(200); });
  server.begin();
}

void loop() {
  server.handleClient();
  if (executando && millis() - lastUpdate > 20) {
    processarMovimento();
    lastUpdate = millis();
  }
}
