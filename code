#include <WiFi.h>
#include <WebServer.h>
#include <ESP32Servo.h>
#include <Preferences.h>

const int pins[] = {13, 12, 14, 27};
Servo servos[4]; // Array corrigido para 4 motores

int posAtuais[] = {90, 90, 90, 90};
int memorias[10][4]; 
int passoVelocidade = 1; 

bool executando = false;
bool modoLoop = false;
int sequencia[50];
int tamSeq = 0, passoAtual = 0;
unsigned long lastUpdate = 0;

Preferences prefs;
WebServer server(80);

const char PAGE[] PROGMEM = R"=====(
